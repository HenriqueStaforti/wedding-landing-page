---
export const prerender = false;

import Layout from "../layouts/Layout.astro";

// Capturar parâmetros da query string
const collection_id = Astro.url.searchParams.get('collection_id');
const collection_status = Astro.url.searchParams.get('collection_status');
const payment_id = Astro.url.searchParams.get('payment_id');
const external_reference = Astro.url.searchParams.get('external_reference');
const payment_type = Astro.url.searchParams.get('payment_type');
const merchant_order_id = Astro.url.searchParams.get('merchant_order_id');
const preference_id = Astro.url.searchParams.get('preference_id');
---

<Layout title="Pagamento Pendente">
  <section 
    class="payment-result pending-section"
    data-collection-id={collection_id}
    data-payment-type={payment_type}
  >
    <div class="container">
      <div class="result-card pending-card">
        <div class="result-icon pending-icon" id="status-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
        </div>
        
        <h1 class="result-title" id="status-title">Pagamento Pendente</h1>
        
        <p class="result-message" id="status-message">
          Seu pagamento está sendo processado. Este pode ser o caso de pagamentos via Boleto ou parcelado em 2 Cartões pendente de confirmação.
        </p>

        <div class="payment-details">
          <h3>Detalhes do Pagamento</h3>
          
          {payment_id && (
            <div class="detail-item">
              <span class="label">ID do Pagamento:</span>
              <span class="value">{payment_id}</span>
            </div>
          )}
          
          {external_reference && (
            <div class="detail-item">
              <span class="label">Presente:</span>
              <span class="value">{external_reference}</span>
            </div>
          )}
          
          {payment_type && (
            <div class="detail-item">
              <span class="label">Forma de Pagamento:</span>
              <span class="value">{payment_type.replace('_', ' ')}</span>
            </div>
          )}
          
          {collection_status && (
            <div class="detail-item">
              <span class="label">Status:</span>
              <span class="value pending-status" id="status-badge">{collection_status}</span>
            </div>
          )}
        </div>

        <!-- <div class="pending-info" id="status-info">
          <h3>O que Acontece Agora?</h3>
          <ul>
            <li>Seu pagamento está sendo validado pela instituição financeira</li>
            <li>Você receberá uma confirmação por email quando o pagamento for aprovado</li>
            <li>Este processo pode levar alguns minutos ou até 24 horas, dependendo do banco</li>
            <li>Enquanto isso, seu presente já fica registrado em nossa lista</li>
          </ul>
        </div> -->

        <div class="action-buttons">
          <a href="/" class="btn btn-primary">Voltar à Página Inicial</a>
          <a href="/wishlist" class="btn btn-secondary">Ver Outros Presentes</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .payment-result {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .pending-section {
    background-color: var(--color-primary);
  }

  .success-section {
    background-color: var(--color-primary);
  }

  .container {
    width: 100%;
    max-width: 600px;
  }

  .result-card {
    background: white;
    border-radius: 16px;
    padding: 3rem 2rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
    text-align: center;
    animation: slideUp 0.6s ease-out;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .result-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.7;
    }
  }

  .pending-icon {
    background: #f59e0b;
    color: white;
  }

  .pending-icon svg {
    width: 40px;
    height: 40px;
  }

  .success-icon {
    background: #10b981;
    color: white;
    animation: none;
  }

  .success-icon svg {
    width: 40px;
    height: 40px;
  }

  .result-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .result-message {
    font-size: 1.1rem;
    color: var(--color-text);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .payment-details {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    border-radius: 12px;
    padding: 1.5rem;
    margin: 2rem 0;
    text-align: left;
    border-left: 4px solid var(--color-accent);
  }

  .payment-details h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .detail-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0;
    border-bottom: 1px solid #e5e7eb;
  }

  .detail-item:last-child {
    border-bottom: none;
  }

  .label {
    font-weight: 500;
    color: var(--color-primary);
  }

  .value {
    color: var(--color-primary);
    font-weight: 600;
    word-break: break-all;
  }

  .pending-status {
    color: #f59e0b;
  }

  .success-status {
    color: #10b981;
  }

  .pending-info {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    border-radius: 12px;
    padding: 1.5rem;
    margin: 2rem 0;
    text-align: left;
    border-left: 4px solid var(--color-accent);
  }

  .pending-info h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-secondary);
    margin-bottom: 1rem;
  }

  .pending-info ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .pending-info li {
    padding: 0.5rem 0;
    color: var(--color-secondary);
    padding-left: 1.5rem;
    position: relative;
  }

  .pending-info li:before {
    content: "✓";
    position: absolute;
    left: 0;
    font-weight: bold;
  }

  .action-buttons {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .btn {
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    flex: 1;
    min-width: 120px;
    text-align: center;
  }

  .btn-primary {
    background-color: var(--color-primary);
    color: var(--color-secondary);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
    opacity: 0.9;
  }

  .btn-secondary {
    background: white;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
  }

  .btn-secondary:hover {
    background: var(--color-primary);
    color: white;
    transform: translateY(-2px);
  }

  @media (max-width: 600px) {
    .result-card {
      padding: 2rem 1.5rem;
    }

    .result-title {
      font-size: 1.5rem;
    }

    .action-buttons {
      flex-direction: column;
    }

    .btn {
      width: 100%;
    }
  }
</style>
<script>
  // Check PIX payment status if it's a bank_transfer
  async function checkPixStatus() {
    const section = document.querySelector('[data-payment-type]');
    if (!section) return;

    const paymentType = section.getAttribute('data-payment-type');
    const collectionId = section.getAttribute('data-collection-id');

    // Only check for PIX payments
    if (paymentType !== 'bank_transfer' || !collectionId) {
      console.log("Not a PIX payment or missing collection_id");
      return;
    }

    try {
      const response = await fetch(`/api/check-pix-status?collection_id=${collectionId}`);
      
      if (!response.ok) {
        console.error("Failed to check PIX status:", response.statusText);
        return;
      }

      const data = await response.json();
      console.log("PIX Status Check Result:", data);

      if (data.isApproved) {
        updateToApprovedState(data);
      }
    } catch (error) {
      console.error("Error checking PIX status:", error);
    }
  }

  function updateToApprovedState(paymentData) {
    // Update icon
    const iconElement = document.getElementById('status-icon');
    if (iconElement) {
      iconElement.className = 'result-icon success-icon';
      iconElement.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>';
    }

    // Update title
    const titleElement = document.getElementById('status-title');
    if (titleElement) {
      titleElement.textContent = 'Pagamento Aprovado! 🎉';
    }

    // Update message
    const messageElement = document.getElementById('status-message');
    if (messageElement) {
      messageElement.textContent = 'Seu PIX foi confirmado! Obrigado por sua generosidade. Seu presente foi confirmado em nossa lista.';
    }

    // Update status badge
    const badgeElement = document.getElementById('status-badge');
    if (badgeElement) {
      badgeElement.className = 'value success-status';
      badgeElement.textContent = paymentData.status;
    }

    // Update info section
    const infoElement = document.getElementById('status-info');
    if (infoElement) {
      infoElement.innerHTML = '';
    }
  }

  // Check status on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', checkPixStatus);
  } else {
    checkPixStatus();
  }
</script>